# 로컬: docker compose up -d postgres 후 그대로 사용
DATABASE_URL="postgresql://duction:duction@localhost:5432/duction"
# 운영: 관리형 Postgres (Neon/Supabase 등) 커넥션 스트링으로 교체 — DEPLOY.md 참조
# NEXT_PUBLIC_SITE_URL="https://duction.co"  # OG 카드 절대 URL용
# 웹푸시 — npx web-push generate-vapid-keys 로 발급
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# Redis — 레이트 리밋 (없으면 fail-open)
REDIS_URL="redis://localhost:6379"
# FCM 네이티브 푸시 (M19) — Firebase 콘솔 > 서비스 계정 > 비공개 키 JSON (원문 또는 base64)
FCM_SERVICE_ACCOUNT_JSON=""

# 운영 — Cloudflare R2 이미지 (미설정 시 로컬 저장)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="duction-media"
R2_PUBLIC_URL=""  # 예: https://media.duction.co
# 운영 — 정산 크론 보호 (Cloud Scheduler 헤더 x-cron-secret)
CRON_SECRET=""
